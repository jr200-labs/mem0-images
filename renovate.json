{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>jr200-labs/github-action-templates"],
  "regexManagers": [
    {
      "fileMatch": [
        "^images/mem0-dashboard/Dockerfile$",
        "^images/mem0-api-server/Dockerfile$"
      ],
      "matchStrings": [
        "ARG MEM0_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "mem0ai/mem0",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver-coerced"
    }
  ]
}
