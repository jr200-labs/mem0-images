{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>jr200-labs/github-action-templates"],
  "regexManagers": [
    {
      "fileMatch": ["^\\.github/images\\.yaml$"],
      "matchStrings": [
        "context: https://github\\.com/mem0ai/mem0\\.git#(?<currentValue>v[^:]+):server(?:/dashboard)?"
      ],
      "depNameTemplate": "mem0ai/mem0",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver-coerced"
    }
  ]
}
